# Frontend (local dev). On Vercel, set these in Project → Settings → Environment Variables.
VITE_API_URL=http://127.0.0.1:5000/api

# Supabase (public anon key only — never put service_role here)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# DeepSeek (teacher AI) — put the key in backend/.env only (Flask reads it there).
# For production, add DEEPSEEK_API_KEY in Railway → Variables (not in git).
